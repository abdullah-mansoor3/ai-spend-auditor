# AI Spend Auditor — local environment variables
# Copy this file to .env and fill in your values
# On Streamlit Community Cloud, add these in Settings → Secrets

# Required: Groq inference for report narrative generation
# Get from: https://console.groq.com/keys
GROQ_API_KEY=gsk_...

# Optional: Second and third Groq keys for key rotation (if rate limited)
GROQ_API_KEY_2=gsk_...
GROQ_API_KEY_3=gsk_...

# Required: PostHog analytics
# Get from: https://app.posthog.com/project/settings
POSTHOG_API_KEY=phc_...

# Optional: PostHog host (defaults to https://us.i.posthog.com)
POSTHOG_HOST=https://us.i.posthog.com
